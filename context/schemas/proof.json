{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "claim",
    "proof_type",
    "metric_or_mechanism",
    "scope",
    "freshness_of_data",
    "attributable_to_product",
    "audience_understandable",
    "evidence",
    "source_refs",
    "confidence",
    "freshness",
    "status",
    "pipeline"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "proof"
    },
    "claim": {
      "type": "string"
    },
    "proof_type": {
      "enum": [
        "numeric",
        "mechanistic"
      ]
    },
    "metric_or_mechanism": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "freshness_of_data": {
      "type": "string"
    },
    "attributable_to_product": {
      "type": "boolean"
    },
    "audience_understandable": {
      "type": "boolean"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freshness": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "needs-review",
        "approved",
        "rejected"
      ]
    },
    "pipeline": {
      "const": "proof-truth"
    }
  }
}
