{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Persona",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "label",
    "role",
    "company_type",
    "sophistication",
    "buying_trigger",
    "care_about",
    "typical_objections",
    "evidence",
    "source_refs",
    "confidence",
    "freshness",
    "status",
    "pipeline"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "persona"
    },
    "label": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "company_type": {
      "type": "string"
    },
    "sophistication": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "buying_trigger": {
      "type": "string"
    },
    "care_about": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "typical_objections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freshness": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "needs-review",
        "approved",
        "rejected"
      ]
    },
    "pipeline": {
      "const": "commercial-truth"
    }
  }
}
