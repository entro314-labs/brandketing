{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Competitor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "name",
    "category",
    "key_claims",
    "weakness",
    "overlap_with_us",
    "source_refs",
    "confidence",
    "freshness",
    "status",
    "pipeline"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "competitor"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "enum": [
        "direct",
        "indirect",
        "internal-workflow",
        "agency-consultant",
        "spreadsheet-manual",
        "status-quo"
      ]
    },
    "key_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weakness": {
      "type": "string"
    },
    "overlap_with_us": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freshness": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "needs-review",
        "approved",
        "rejected"
      ]
    },
    "pipeline": {
      "const": "market-truth"
    }
  }
}
