{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "surface_pain",
    "hidden_pain",
    "persona",
    "stage",
    "frequency",
    "severity",
    "downstream_consequence",
    "evidence",
    "source_refs",
    "confidence",
    "freshness",
    "status",
    "pipeline"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "pain"
    },
    "surface_pain": {
      "type": "string"
    },
    "hidden_pain": {
      "type": "string"
    },
    "persona": {
      "type": "string"
    },
    "stage": {
      "enum": [
        "awareness",
        "consideration",
        "activation",
        "retention",
        "expansion"
      ]
    },
    "frequency": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "severity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "downstream_consequence": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freshness": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "needs-review",
        "approved",
        "rejected"
      ]
    },
    "pipeline": {
      "const": "customer-truth"
    }
  }
}
