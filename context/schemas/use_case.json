{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Use Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "job_statement",
    "trigger_moment",
    "persona",
    "pain_before",
    "desired_outcome",
    "relevant_capability_ids",
    "evidence_count",
    "source_refs",
    "confidence",
    "freshness",
    "status",
    "pipeline"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "use_case"
    },
    "job_statement": {
      "type": "string"
    },
    "trigger_moment": {
      "type": "string"
    },
    "persona": {
      "type": "string"
    },
    "pain_before": {
      "type": "string"
    },
    "desired_outcome": {
      "type": "string"
    },
    "relevant_capability_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freshness": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "needs-review",
        "approved",
        "rejected"
      ]
    },
    "pipeline": {
      "const": "customer-truth"
    }
  }
}
